---
import curriculum from '../data/curriculum.json';

const phases = curriculum.phases;
---

<div class="space-y-6">
  <!-- Quick stats -->
  <div class="p-5 rounded-2xl bg-slate-800/50 border border-slate-700/50">
    <h3 class="font-bold text-white mb-4">📊 Overview</h3>
    <div class="space-y-3 text-sm">
      <div class="flex justify-between">
        <span class="text-slate-400">Duration</span>
        <span class="text-white font-semibold">{curriculum.totalMonths} months</span>
      </div>
      <div class="flex justify-between">
        <span class="text-slate-400">Weeks</span>
        <span class="text-white font-semibold">{curriculum.totalWeeks}</span>
      </div>
      <div class="flex justify-between">
        <span class="text-slate-400">Phases</span>
        <span class="text-white font-semibold">{phases.length}</span>
      </div>
      <div class="flex justify-between">
        <span class="text-slate-400">Milestones</span>
        <span class="text-white font-semibold">{curriculum.milestones.length}</span>
      </div>
    </div>
  </div>

  <!-- Phase navigation -->
  <div class="p-5 rounded-2xl bg-slate-800/50 border border-slate-700/50">
    <h3 class="font-bold text-white mb-4">🧭 Phases</h3>
    <nav class="space-y-2">
      {phases.map((phase) => (
        <a 
          href={`#phase-${phase.id}`}
          class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-700/50 transition-colors text-sm group"
        >
          <span class="text-lg">{phase.emoji}</span>
          <div class="flex-1">
            <div class="text-white group-hover:text-indigo-300 transition-colors">
              {phase.title}
            </div>
            <div class="text-xs text-slate-500">
              Week {phase.weeks}
            </div>
          </div>
        </a>
      ))}
    </nav>
  </div>

  <!-- FDE Focus Areas -->
  <div class="p-5 rounded-2xl bg-slate-800/50 border border-slate-700/50">
    <h3 class="font-bold text-white mb-4">🎯 FDE Focus Areas</h3>
    <div class="space-y-2 text-sm">
      <div class="flex items-center gap-2 text-green-400">
        <span>→</span> Technical breadth (frontend + backend + infra)
      </div>
      <div class="flex items-center gap-2 text-blue-400">
        <span>→</span> Customer-facing problem solving
      </div>
      <div class="flex items-center gap-2 text-purple-400">
        <span>→</span> Rapid deployment & integration
      </div>
      <div class="flex items-center gap-2 text-amber-400">
        <span>→</span> Security & compliance
      </div>
      <div class="flex items-center gap-2 text-cyan-400">
        <span>→</span> Communication & business acumen
      </div>
    </div>
  </div>

  <!-- Time commitment -->
  <div class="p-5 rounded-2xl bg-slate-800/50 border border-slate-700/50">
    <h3 class="font-bold text-white mb-4">⏱️ Time Commitment</h3>
    <div class="space-y-3 text-sm">
      <div class="p-3 rounded-lg bg-green-500/10 border border-green-500/20">
        <div class="font-semibold text-green-400">🐢 Casual</div>
        <div class="text-slate-400 text-xs mt-1">5-7h/week → ~22 months</div>
      </div>
      <div class="p-3 rounded-lg bg-blue-500/10 border border-blue-500/20">
        <div class="font-semibold text-blue-400">🚶 Moderate</div>
        <div class="text-slate-400 text-xs mt-1">10-15h/week → ~18 months</div>
      </div>
      <div class="p-3 rounded-lg bg-amber-500/10 border border-amber-500/20">
        <div class="font-semibold text-amber-400">🏃 Aggressive</div>
        <div class="text-slate-400 text-xs mt-1">20-30h/week → ~14 months</div>
      </div>
      <div class="p-3 rounded-lg bg-red-500/10 border border-red-500/20">
        <div class="font-semibold text-red-400">🔥 Full-time</div>
        <div class="text-slate-400 text-xs mt-1">40h/week → ~10 months</div>
      </div>
    </div>
  </div>

  <!-- Target Roles -->
  <div class="p-5 rounded-2xl bg-slate-800/50 border border-slate-700/50">
    <h3 class="font-bold text-white mb-4">🏢 Target Companies</h3>
    <div class="space-y-2 text-sm">
      <div class="text-slate-300">Palantir (FDE pioneer)</div>
      <div class="text-slate-300">Stripe (Forward Deployed)</div>
      <div class="text-slate-300">AWS (Customer Engineers)</div>
      <div class="text-slate-300">Google Cloud (CE roles)</div>
      <div class="text-slate-300">B2B SaaS startups</div>
      <div class="text-slate-300">GoTo/Grab/Shopee (Solution Engineers)</div>
    </div>
  </div>
</div>
