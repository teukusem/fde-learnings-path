---
import curriculum from '../data/curriculum.json';

const stack = curriculum.techStack;
const docs = stack.docs;
---

<section id="tech-stack" class="py-16">
  <div class="text-center mb-12">
    <h2 class="text-4xl font-bold text-white mb-4">Complete Tech Stack</h2>
    <p class="text-slate-400 text-lg">Frontend → Backend → DevOps → Security — everything an FDE needs</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Core -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-indigo-500/10 to-purple-500/10 border border-indigo-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-indigo-500/20 rounded-lg flex items-center justify-center">⚡</span>
        Core
      </h3>
      <ul class="space-y-2">
        {stack.core.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- Frontend -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-purple-500/10 to-pink-500/10 border border-purple-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-purple-500/20 rounded-lg flex items-center justify-center">⚛️</span>
        Frontend
      </h3>
      <ul class="space-y-2">
        {stack.framework.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-purple-400 rounded-full"></span>
            {tech}
          </li>
        ))}
        {stack.styling.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-purple-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- Backend -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-blue-500/10 to-cyan-500/10 border border-blue-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-blue-500/20 rounded-lg flex items-center justify-center">🔧</span>
        Backend
      </h3>
      <ul class="space-y-2">
        {stack.backend.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-blue-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- Databases -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-cyan-500/10 to-teal-500/10 border border-cyan-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-cyan-500/20 rounded-lg flex items-center justify-center">🗄️</span>
        Databases
      </h3>
      <ul class="space-y-2">
        {stack.databases.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- DevOps -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-amber-500/10 to-orange-500/10 border border-amber-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-amber-500/20 rounded-lg flex items-center justify-center">☁️</span>
        DevOps & Cloud
      </h3>
      <ul class="space-y-2">
        {stack.devops.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-amber-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- Security -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-red-500/10 to-rose-500/10 border border-red-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-red-500/20 rounded-lg flex items-center justify-center">🔒</span>
        Security
      </h3>
      <ul class="space-y-2">
        {stack.security.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-red-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- Monitoring -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-green-500/10 to-emerald-500/10 border border-green-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-green-500/20 rounded-lg flex items-center justify-center">📊</span>
        Monitoring
      </h3>
      <ul class="space-y-2">
        {stack.monitoring.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- Testing -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-slate-500/10 to-gray-500/10 border border-slate-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-slate-500/20 rounded-lg flex items-center justify-center">🧪</span>
        Testing
      </h3>
      <ul class="space-y-2">
        {stack.testing.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-slate-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>

    <!-- Forms & State -->
    <div class="p-6 rounded-2xl bg-gradient-to-br from-violet-500/10 to-fuchsia-500/10 border border-violet-500/20">
      <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
        <span class="w-8 h-8 bg-violet-500/20 rounded-lg flex items-center justify-center">📝</span>
        Forms & State
      </h3>
      <ul class="space-y-2">
        {stack.state.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-violet-400 rounded-full"></span>
            {tech}
          </li>
        ))}
        {stack.forms.map((tech) => (
          <li class="text-slate-300 text-sm flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-violet-400 rounded-full"></span>
            {tech}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Docs Links -->
  <div class="mt-12 p-6 rounded-2xl bg-slate-800/50 border border-slate-700/50">
    <h3 class="text-lg font-bold text-white mb-4">📚 Official Documentation</h3>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {Object.entries(docs).map(([key, url]) => (
        <a 
          href={url} 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-2 p-2 rounded-lg hover:bg-slate-700/50"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          {key.charAt(0).toUpperCase() + key.slice(1).replace(/([A-Z])/g, ' $1')}
        </a>
      ))}
    </div>
  </div>
</section>
