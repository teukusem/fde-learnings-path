---
// Hero section
---

<section class="relative py-20 md:py-32 overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-500/10 rounded-full blur-3xl"></div>
  <div class="absolute top-20 right-20 w-72 h-72 bg-cyan-500/10 rounded-full blur-3xl"></div>
  
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-sm mb-8">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
      </span>
      72 Weeks to FDE
    </div>

    <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
      Forward Deployed
      <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">
        Engineer
      </span>
    </h1>

    <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-2xl mx-auto">
      Complete path from Frontend Engineer to FDE.
      <span class="text-slate-400">18 months. Self-paced. End-to-end.</span>
    </p>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <span class="px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm">JavaScript + TypeScript</span>
      <span class="px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-400 text-sm">React + Next.js</span>
      <span class="px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm">Backend + APIs</span>
      <span class="px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-sm">DevOps + Cloud</span>
      <span class="px-3 py-1 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-sm">Security</span>
      <span class="px-3 py-1 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm">FDE Skills</span>
    </div>

    <div class="grid grid-cols-3 gap-8 max-w-lg mx-auto">
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">6</div>
        <div class="text-sm text-slate-400">Phases</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">72</div>
        <div class="text-sm text-slate-400">Weeks</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">13</div>
        <div class="text-sm text-slate-400">Milestones</div>
      </div>
    </div>

    <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#timeline" class="px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold rounded-xl transition-all hover:scale-105 shadow-lg shadow-indigo-500/25">
        Start Learning →
      </a>
      <a href="https://github.com/teukusem/fde-learnings-path" target="_blank" rel="noopener" class="px-8 py-4 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-xl transition-all border border-slate-600 hover:border-slate-500">
        ⭐ GitHub
      </a>
    </div>
  </div>
</section>
