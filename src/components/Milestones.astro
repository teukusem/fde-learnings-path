---
import curriculum from '../data/curriculum.json';

const milestones = curriculum.milestones;

const phaseColors = [
  { bg: 'bg-green-500', text: 'text-green-400', label: 'JS Foundation' },
  { bg: 'bg-blue-500', text: 'text-blue-400', label: 'JS Advanced' },
  { bg: 'bg-purple-500', text: 'text-purple-400', label: 'JS Async' },
  { bg: 'bg-amber-500', text: 'text-amber-400', label: 'JS DOM' },
  { bg: 'bg-red-500', text: 'text-red-400', label: 'JS Complete' },
  { bg: 'bg-cyan-500', text: 'text-cyan-400', label: 'TypeScript' },
  { bg: 'bg-pink-500', text: 'text-pink-400', label: 'React' },
  { bg: 'bg-emerald-500', text: 'text-emerald-400', label: 'CSS & A11y' },
  { bg: 'bg-orange-500', text: 'text-orange-400', label: 'Next.js' },
  { bg: 'bg-indigo-500', text: 'text-indigo-400', label: 'FDE Ready' }
];
---

<section id="milestones" class="py-16">
  <div class="text-center mb-12">
    <h2 class="text-4xl font-bold text-white mb-4">Milestones & Checkpoints</h2>
    <p class="text-slate-400 text-lg">Track your progress every 4-8 weeks</p>
  </div>

  <!-- Progress bar -->
  <div class="mb-12 p-6 rounded-2xl bg-slate-800/50 border border-slate-700/50">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm text-slate-400">Overall Progress</span>
      <span class="text-sm text-white font-semibold" id="progress-text">0 / {milestones.length}</span>
    </div>
    <div class="w-full h-3 bg-slate-700 rounded-full overflow-hidden">
      <div id="progress-bar" class="h-full bg-gradient-to-r from-indigo-500 to-cyan-500 rounded-full transition-all duration-500" style="width: 0%"></div>
    </div>
  </div>

  <!-- Timeline -->
  <div class="relative">
    <!-- Vertical line -->
    <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-slate-700"></div>

    <div class="space-y-8">
      {milestones.map((milestone, index) => {
        const color = phaseColors[index] || phaseColors[0];
        
        return (
          <div class="relative flex items-start gap-6 group">
            <!-- Dot -->
            <div class={`relative z-10 w-12 h-12 rounded-full ${color.bg} flex items-center justify-center flex-shrink-0 shadow-lg`}>
              <span class="text-white font-bold text-sm">{milestone.week}</span>
            </div>

            <!-- Content -->
            <div class="flex-1 p-5 rounded-xl bg-slate-800/50 border border-slate-700/50 hover:border-slate-600/50 transition-all">
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-bold text-white">{milestone.title}</h3>
                <input 
                  type="checkbox" 
                  class="milestone-check" 
                  data-milestone={milestone.week}
                  aria-label={`Mark milestone ${milestone.week} complete`}
                />
              </div>
              <p class="text-slate-400 text-sm">{milestone.check}</p>
              <div class="mt-3">
                <span class={`text-xs ${color.text} bg-slate-900/50 px-2 py-1 rounded`}>
                  Week {milestone.week}
                </span>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .milestone-check {
    appearance: none;
    width: 24px;
    height: 24px;
    border: 2px solid #475569;
    border-radius: 6px;
    cursor: pointer;
    position: relative;
    transition: all 0.2s;
  }
  .milestone-check:hover {
    border-color: #6366f1;
  }
  .milestone-check:checked {
    background: #6366f1;
    border-color: #6366f1;
  }
  .milestone-check:checked::after {
    content: '✓';
    position: absolute;
    color: white;
    font-size: 16px;
    top: -1px;
    left: 4px;
    font-weight: bold;
  }
</style>

<script>
  // Load & save milestone states
  function updateProgress() {
    const checks = document.querySelectorAll('.milestone-check') as NodeListOf<HTMLInputElement>;
    const completed = Array.from(checks).filter(c => c.checked).length;
    const total = checks.length;
    
    const progressBar = document.getElementById('progress-bar');
    const progressText = document.getElementById('progress-text');
    
    if (progressBar) {
      progressBar.style.width = `${(completed / total) * 100}%`;
    }
    if (progressText) {
      progressText.textContent = `${completed} / ${total}`;
    }
  }

  document.querySelectorAll('.milestone-check').forEach((checkbox) => {
    const input = checkbox as HTMLInputElement;
    const milestoneId = input.dataset.milestone;
    
    if (milestoneId) {
      // Load saved state
      const saved = localStorage.getItem(`milestone-${milestoneId}`);
      if (saved === 'true') {
        input.checked = true;
      }
      
      // Save on change
      input.addEventListener('change', () => {
        localStorage.setItem(`milestone-${milestoneId}`, input.checked.toString());
        updateProgress();
      });
    }
  });

  // Initial progress update
  updateProgress();
</script>
